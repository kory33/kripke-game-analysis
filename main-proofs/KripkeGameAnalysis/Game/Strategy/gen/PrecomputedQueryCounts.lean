  have h := congrArg (fun arr => arr[idx]'(by simpa [Array.size_ofFn, computedQueryCountTable_0] using idx.isLt)) queryCountTable_0_spec
  simpa [computedQueryCountTable_0] using h

def queryCount_0 (frameId : Fin 65536) : Nat :=
  let idx := canonicalFrameIndex frameId
  if h : idx < canonicalFrameCount then
    queryCountTable_0.val[⟨idx, h⟩]'(by simpa [queryCountTable_0.property] using h)
  else
    (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query_0

theorem queryCount_0_eq_actual (frameId : Fin 65536) :
    queryCount_0 frameId = (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query_0 := by
  unfold queryCount_0
  dsimp
  split <;> rename_i h
  · have hidx := queryCountTable_0_eq_actual_at_index ⟨canonicalFrameIndex frameId, h⟩
    rw [canonicalFrameId_of_canonicalFrameIndex frameId h] at hidx
    simpa [canonicalFrameIndex, h] using hidx
  · simp [h, canonicalFrameIndex]

