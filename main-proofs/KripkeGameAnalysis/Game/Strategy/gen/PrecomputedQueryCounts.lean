  else if h_11 : query = query_11 then queryCount_11 frameId
  else if h_12 : query = query_12 then queryCount_12 frameId
  else if h_13 : query = query_13 then queryCount_13 frameId
  else if h_14 : query = query_14 then queryCount_14 frameId
  else (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query

theorem precomputedCountSatisfyingNodes_eq_actual (frameId : Fin 65536) (query : ModalFormula KripkeGameVars) :
    precomputedCountSatisfyingNodes frameId query = (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query := by
  unfold precomputedCountSatisfyingNodes
  by_cases h_0 : query = query_0
  · simp [h_0, queryCount_0_eq_actual]
  by_cases h_1 : query = query_1
  · simp [h_1, queryCount_1_eq_actual]
  by_cases h_2 : query = query_2
  · simp [h_2, queryCount_2_eq_actual]
  by_cases h_3 : query = query_3
  · simp [h_3, queryCount_3_eq_actual]
  by_cases h_4 : query = query_4
  · simp [h_4, queryCount_4_eq_actual]
  by_cases h_5 : query = query_5
