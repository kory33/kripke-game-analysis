  by_cases h_7 : query = query_7
  · simp [h_7, queryCount_7_eq_actual]
  by_cases h_8 : query = query_8
  · simp [h_8, queryCount_8_eq_actual]
  by_cases h_9 : query = query_9
  · simp [h_9, queryCount_9_eq_actual]
