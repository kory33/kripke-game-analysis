def queryCountTable_14 : { table : Array Nat // table.size = canonicalFrameCount } :=
  ⟨
    queryCountTable_14_chunk_0
    ++ queryCountTable_14_chunk_1
    ++ queryCountTable_14_chunk_2
    ++ queryCountTable_14_chunk_3
    ++ queryCountTable_14_chunk_4
    ++ queryCountTable_14_chunk_5
  , by native_decide
  ⟩

private def computedQueryCountTable_14 : Array Nat :=
  Array.ofFn (fun idx : Fin canonicalFrameCount => ((FiniteKripkeFrame.ofFin (n := 4) (canonicalFrameId idx)).countSatisfyingNodes query_14))

theorem queryCountTable_14_spec : queryCountTable_14.val = computedQueryCountTable_14 := by
  native_decide

theorem queryCountTable_14_eq_actual_at_index (idx : Fin canonicalFrameCount) :
    queryCountTable_14.val[idx]'(by simpa [queryCountTable_14.property] using idx.isLt) = (FiniteKripkeFrame.ofFin (n := 4) (canonicalFrameId idx)).countSatisfyingNodes query_14 := by
  have h := congrArg (fun arr => arr[idx]'(by simpa [Array.size_ofFn, computedQueryCountTable_14] using idx.isLt)) queryCountTable_14_spec
  simpa [computedQueryCountTable_14] using h

def queryCount_14 (frameId : Fin 65536) : Nat :=
  let idx := canonicalFrameIndex frameId
  if h : idx < canonicalFrameCount then
    queryCountTable_14.val[⟨idx, h⟩]'(by simpa [queryCountTable_14.property] using h)
  else
    (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query_14

theorem queryCount_14_eq_actual (frameId : Fin 65536) :
    queryCount_14 frameId = (FiniteKripkeFrame.ofFin (n := 4) frameId).countSatisfyingNodes query_14 := by
  unfold queryCount_14
  dsimp
  split <;> rename_i h
  · have hidx := queryCountTable_14_eq_actual_at_index ⟨canonicalFrameIndex frameId, h⟩
    rw [canonicalFrameId_of_canonicalFrameIndex frameId h] at hidx
    simpa [canonicalFrameIndex, h] using hidx
  · simp [h, canonicalFrameIndex]

/-- Count satisfying nodes using precomputed tables for the queries used in the generated strategy. -/
def precomputedCountSatisfyingNodes (frameId : Fin 65536) (query : ModalFormula KripkeGameVars) : Nat :=
  if h_0 : query = query_0 then queryCount_0 frameId
  else if h_1 : query = query_1 then queryCount_1 frameId
  else if h_2 : query = query_2 then queryCount_2 frameId
  else if h_3 : query = query_3 then queryCount_3 frameId
  else if h_4 : query = query_4 then queryCount_4 frameId
  else if h_5 : query = query_5 then queryCount_5 frameId
  else if h_6 : query = query_6 then queryCount_6 frameId
  else if h_7 : query = query_7 then queryCount_7 frameId
  else if h_8 : query = query_8 then queryCount_8 frameId
  else if h_9 : query = query_9 then queryCount_9 frameId
